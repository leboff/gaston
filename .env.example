# Gaston configuration
#
# NOTE: There is NO OpenRouter API key here. Gaston is BYOK ("bring your own
# key") — each user pastes their own OpenRouter key into the in-app Settings
# panel and it is stored in their browser, never on the server.

# Secret used to encrypt the session cookie (atproto login). Must be >= 32 chars.
# Generate one with:  openssl rand -base64 32
COOKIE_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Public base URL of the app. Used to build the atproto OAuth client metadata
# and redirect URI.
#
# - Local dev: leave as the loopback address below. atproto's "localhost"
#   development client is used automatically, so the app MUST be opened at
#   http://127.0.0.1:3000 (NOT http://localhost:3000).
# - Production: set to your public HTTPS origin, e.g. https://gaston.example.com
#   The app will serve its client metadata at <PUBLIC_URL>/oauth/client-metadata.json
PUBLIC_URL=http://127.0.0.1:3000
